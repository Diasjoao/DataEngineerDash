    <div class="form-group">
      <label class="form-label">Comentário</label>
      <textarea class="form-textarea" id="modal-comment" placeholder="Justificativa..."></textarea>
    </div>
  `;
  document.getElementById('modal-approve').classList.add('open');
}

function approveRequest() {
  closeModal('modal-approve');
  if (currentApproveId) {
    const r = REQUESTS.find(req => req.id === currentApproveId);
    r.status = 'APPROVED';
    renderRequestsTable();
    renderApprovals();
    document.getElementById('approval-badge').textContent = REQUESTS.filter(r=>r.status==='PENDING').length;
    showToast('✅', `Pedido ${currentApproveId} aprovado! Conta sendo criada.`, 'green');
  }
}

function rejectRequest() {
  closeModal('modal-approve');
  if (currentApproveId) {
    const r = REQUESTS.find(req => req.id === currentApproveId);
    r.status = 'REJECTED';
    renderRequestsTable();
    renderApprovals();
    document.getElementById('approval-badge').textContent = REQUESTS.filter(r=>r.status==='PENDING').length;
    showToast('✕', `Pedido ${currentApproveId} reprovado.`, 'red');
  }
}

function approveRequestId(id) {
  const r = REQUESTS.find(req => req.id === id);
  if (r) r.status = 'APPROVED';
  renderRequestsTable();
  renderApprovals();
  document.getElementById('approval-badge').textContent = REQUESTS.filter(r=>r.status==='PENDING').length;
  showToast('✅', `Pedido ${id} aprovado! Conta AWS sendo provisionada.`, 'green');
}

function rejectRequestId(id) {
  const r = REQUESTS.find(req => req.id === id);
  if (r) r.status = 'REJECTED';
  renderRequestsTable();
  renderApprovals();
  document.getElementById('approval-badge').textContent = REQUESTS.filter(r=>r.status==='PENDING').length;
  showToast('✕', `Pedido ${id} reprovado.`, 'red');
}

function submitRequest() {
  const project = document.getElementById('f-project').value;
  const cc = document.getElementById('f-cc').value;
  const purpose = document.getElementById('f-purpose').value;
  
  if (!project || !cc || !purpose) {
    showToast('⚠️', 'Preencha os campos obrigatórios', 'yellow');
    return;
  }
  if (selectedResources.size === 0) {
    showToast('⚠️', 'Selecione pelo menos um recurso AWS', 'yellow');
    return;
  }
  
  const tag = document.getElementById('tag-preview').textContent;
  const newId = 'REQ-' + String(REQUESTS.length + 1).padStart(4, '0');
  REQUESTS.push({
    id: newId,
    project,
    requester: 'João Dias',
    purpose: document.getElementById('f-purpose').options[document.getElementById('f-purpose').selectedIndex].text,
    resources: [...selectedResources].map(id => AWS_RESOURCES.find(r=>r.id===id)?.name || id),
    budget: parseInt(document.getElementById('f-budget').value) || 0,
    status: 'PENDING',
    date: new Date().toISOString().split('T')[0],
    tag,
  });
  
  renderRequestsTable();
  renderApprovals();
  document.getElementById('pending-badge').textContent = REQUESTS.filter(r=>r.status==='PENDING').length;
  document.getElementById('approval-badge').textContent = REQUESTS.filter(r=>r.status==='PENDING').length;
  closeModal('modal-new-request');
  showToast('📤', `Pedido ${newId} enviado para aprovação! Tag: ${tag}`, 'green');
}

function saveDraft() {
  const project = document.getElementById('f-project').value || 'Sem nome';
  const newId = 'REQ-' + String(REQUESTS.length + 1).padStart(4, '0');
  REQUESTS.push({
    id: newId, project, requester: 'João Dias', purpose: 'N/A',
    resources: [...selectedResources], budget: 0, status: 'DRAFT',
    date: new Date().toISOString().split('T')[0],
  });
  renderRequestsTable();
  closeModal('modal-new-request');
  showToast('💾', `Rascunho ${newId} salvo com sucesso`, 'blue');
}

// ========== TOAST ==========
function showToast(icon, msg, type) {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  const colors = { green: 'var(--green)', red: 'var(--red)', yellow: 'var(--yellow)', blue: 'var(--blue2)' };
  toast.className = 'toast';
  toast.style.borderLeftColor = colors[type] || 'var(--border2)';
  toast.style.borderLeftWidth = '3px';
  toast.innerHTML = `<span class="toast-icon">${icon}</span><span class="toast-msg">${msg}</span>`;
  container.appendChild(toast);
  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translateX(20px)';
    toast.style.transition = 'all 0.3s ease';
    setTimeout(() => toast.remove(), 300);
  }, 3500);
}

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.classList.remove('open');
  });
});
</script>
